# ---------------------------------------------------------------------------
# Frontend env vars
# ---------------------------------------------------------------------------
# These are read by Vite at BUILD time (not runtime). Set them in Vercel's
# project Environment Variables UI (Production + Preview), then redeploy.
#
# On Replit (same-origin dev), leave BOTH unset — the app falls back to
# `import.meta.env.BASE_URL` and reaches the API via the shared proxy.

# Absolute URL of the Replit-hosted API server, no trailing slash.
# Example: VITE_API_URL=https://e-migration-assist.<your-id>.replit.app
# Or for the dev domain:
# VITE_API_URL=https://<repl-id>-<hash>.<region>.replit.dev
VITE_API_URL=
